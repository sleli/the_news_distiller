DATABASE_URL="postgresql://user:password@localhost:5432/the_news_distiller"

# Tavily API key — ottieni la tua chiave su https://app.tavily.com
TAVILY_API_KEY=

# Provider AI — valori: anthropic, openai_compatible, claude_subprocess (default: claude_subprocess)
AI_PROVIDER=

# Anthropic API key — ottieni la tua chiave su https://console.anthropic.com
# Richiesta se AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# OpenAI-compatible provider — richiesti se AI_PROVIDER=openai_compatible
# Endpoint base (es. https://openrouter.ai/api/v1)
OPENAI_BASE_URL=
# Chiave API del provider
OPENAI_API_KEY=
# Modello da usare (es. openai/gpt-4o, anthropic/claude-sonnet-4-6)
OPENAI_MODEL=

# Resend API key — ottieni la tua chiave su https://resend.com
RESEND_API_KEY=
# Indirizzo mittente delle email transazionali (opzionale, default: noreply@resend.dev)
RESEND_FROM_EMAIL=
# URL pubblico dell'app — usato nei link "Leggi nella app" nelle email (opzionale, default: http://localhost:3000)
NEXT_PUBLIC_APP_URL=
