generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  name         String?
  image        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     Session[]
  distillJobs  DistillJob[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

model DistillJob {
  id        String          @id @default(uuid())
  userId    String
  topic     String
  tone      String
  status    String          @default("PENDING")
  result    Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources   DistillSource[]

  @@map("distill_jobs")
}

model DistillSource {
  id       String     @id @default(uuid())
  jobId    String
  url      String
  title    String
  excerpt  String
  position String
  job      DistillJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("distill_sources")
}

model AppSettings {
  id         String   @id @default("default")
  claudeMode String   @default("API_KEY")
  updatedAt  DateTime @updatedAt

  @@map("app_settings")
}
